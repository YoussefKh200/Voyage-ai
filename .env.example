# ═══════════════════════════════════════════════════════════════
# VOYAGE AI — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/voyage_ai"

# ─── OpenAI (AI itinerary generation) ─────────────────────────
# Required for real AI generation. Without it, a realistic mock
# is used automatically (great for development/demo).
OPENAI_API_KEY=""
# Model to use (default: gpt-4o). gpt-4o-mini is cheaper for dev.
OPENAI_MODEL="gpt-4o"
# Optional: your OpenAI organisation ID
OPENAI_ORG_ID=""

# ─── Google APIs ───────────────────────────────────────────────
# Server-side unrestricted key — used for Geocoding, Places API
# Keep this secret: never prefix with NEXT_PUBLIC_
GOOGLE_API_KEY=""

# Client-side restricted key — used for Maps JavaScript API
# Restrict in Google Cloud Console: HTTP referrers only
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ─── Weather ───────────────────────────────────────────────────
# Open-Meteo is free and requires NO API key.
# This is a placeholder for AccuWeather / OpenWeatherMap if you
# want to upgrade to a paid provider.
WEATHER_API_KEY=""

# ─── Flight Search (optional) ──────────────────────────────────
# Get keys at: https://developers.amadeus.com (free test tier)
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""

# ─── Rate Limiting (optional overrides) ────────────────────────
# Defaults: 10 itineraries/hour, 60 places/min, 30 weather/min
RATE_LIMIT_ITINERARY_PER_HOUR="10"
RATE_LIMIT_PLACES_PER_MIN="60"

# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
