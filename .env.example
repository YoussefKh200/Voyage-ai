# ═══════════════════════════════════════════════════════════════════════════════
# VOYAGE AI — Environment Variables
# Copy this file to .env.local for local development.
# Set these in Vercel Dashboard > Settings > Environment Variables for production.
# NEVER commit .env.local or any file containing real secrets.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV="development"                    # development | production | test
LOG_LEVEL="info"                          # debug | info | warn | error
NEXT_PUBLIC_APP_VERSION="1.0.0"          # Shown in health check + monitoring

# ─── App URL ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# ─── Database ────────────────────────────────────────────────────────────────────
# Required for trip persistence. Get a free DB from:
#   - Vercel Postgres (vercel.com/storage)
#   - Neon (neon.tech) — recommended
#   - Supabase (supabase.com)
DATABASE_URL="postgresql://user:password@localhost:5432/voyage_ai"
# For Vercel Postgres, use the pooled connection string:
# DATABASE_URL="postgres://...@...pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── OpenAI ──────────────────────────────────────────────────────────────────────
# Required for real AI generation. Without it, mock data is used automatically.
# Get your key: platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"                    # gpt-4o | gpt-4o-mini (cheaper for dev)
OPENAI_ORG_ID=""                         # Optional: your OpenAI organisation ID

# ─── Google APIs ─────────────────────────────────────────────────────────────────
# Two separate keys for security:
# 1. Server-side key (unrestricted) — for Places, Geocoding, Routes APIs
#    Create at: console.cloud.google.com > APIs & Services > Credentials
GOOGLE_API_KEY=""
# 2. Client-side key (restricted to HTTP referrers) — for Maps JavaScript API
#    In API key settings: restrict to your domain (e.g., *.vercel.app)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Enable these APIs in Google Cloud Console:
#   - Maps JavaScript API
#   - Places API
#   - Geocoding API
#   - Directions API (for future route display)

# ─── Weather ─────────────────────────────────────────────────────────────────────
# Open-Meteo is used by default — FREE, no key needed.
# Uncomment below only if switching to AccuWeather or OpenWeatherMap:
# WEATHER_API_KEY=""
# WEATHER_PROVIDER="openweathermap"       # openweathermap | accuweather

# ─── Flight Search (Optional) ────────────────────────────────────────────────────
# Enables real flight search (currently shows placeholder data without this)
# Get keys at: developers.amadeus.com (free test tier available)
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""

# ─── Monitoring & Error Tracking ─────────────────────────────────────────────────
# Sentry — error tracking and performance monitoring
# Set up: sentry.io → New Project → Next.js → copy DSN
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Auth token for source map uploads during build
SENTRY_AUTH_TOKEN=""

# ─── Analytics ────────────────────────────────────────────────────────────────────
# Vercel Analytics is automatic — no configuration needed.
# If you want PostHog or Mixpanel:
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── Rate Limiting ────────────────────────────────────────────────────────────────
# For production scale, upgrade to Upstash Redis rate limiting:
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
# Without these, in-process rate limiting is used (fine for single instances)
RATE_LIMIT_ITINERARY_PER_HOUR="10"      # Itinerary generations per IP/hour
RATE_LIMIT_PLACES_PER_MIN="60"          # Places API calls per IP/minute

# ─── Caching (Optional) ──────────────────────────────────────────────────────────
# Upgrade LRU cache to Redis for multi-instance deployments:
# REDIS_URL=""

# ─── Security ─────────────────────────────────────────────────────────────────────
# Add a strong random secret for any future JWT/session signing:
# APP_SECRET="generate-with: openssl rand -base64 32"
