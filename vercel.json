{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "framework": "nextjs",

  "regions": ["iad1"],

  "functions": {
    "app/api/itinerary/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "app/api/replan/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "app/api/optimize/budget/route.ts": {
      "maxDuration": 120,
      "memory": 512
    },
    "app/api/optimize/route/route.ts": {
      "maxDuration": 120,
      "memory": 512
    },
    "app/api/chat/route.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "app/api/gems/route.ts": {
      "maxDuration": 90,
      "memory": 512
    },
    "app/api/places/route.ts": {
      "maxDuration": 15,
      "memory": 256
    },
    "app/api/weather/route.ts": {
      "maxDuration": 15,
      "memory": 256
    },
    "app/api/health/route.ts": {
      "maxDuration": 10,
      "memory": 256
    }
  },

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Powered-By",           "value": "" },
        { "key": "X-DNS-Prefetch-Control",  "value": "on" },
        { "key": "X-Content-Type-Options",  "value": "nosniff" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ],

  "redirects": [
    { "source": "/plan",     "destination": "/planner", "permanent": true  },
    { "source": "/generate", "destination": "/planner", "permanent": true  },
    { "source": "/trip",     "destination": "/planner", "permanent": false }
  ],

  "crons": [
    {
      "path":     "/api/health",
      "schedule": "*/5 * * * *"
    }
  ],

  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
